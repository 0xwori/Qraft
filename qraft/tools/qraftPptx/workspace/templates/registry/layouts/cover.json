{
  "schemaVersion": 1,
  "id": "cover",
  "name": "Cover",
  "purpose": "Strong title slide with subtitle and presenter/date.",
  "slots": [
    {
      "id": "title",
      "name": "Title",
      "required": true,
      "supportedBlockTypes": [
        "text"
      ],
      "defaultFrame": {
        "x": 96,
        "y": 152,
        "width": 760,
        "height": 130
      }
    },
    {
      "id": "subtitle",
      "name": "Subtitle",
      "required": false,
      "supportedBlockTypes": [
        "text"
      ],
      "defaultFrame": {
        "x": 96,
        "y": 300,
        "width": 620,
        "height": 84
      }
    },
    {
      "id": "meta",
      "name": "Meta",
      "required": false,
      "supportedBlockTypes": [
        "text"
      ],
      "defaultFrame": {
        "x": 96,
        "y": 514,
        "width": 440,
        "height": 48
      }
    },
    {
      "id": "visual",
      "name": "Visual",
      "required": false,
      "supportedBlockTypes": [
        "image",
        "shape",
        "placeholder"
      ],
      "defaultFrame": {
        "x": 888,
        "y": 0,
        "width": 392,
        "height": 720
      }
    }
  ],
  "defaultBlocks": [
    {
      "type": "text",
      "slot": "title",
      "textRole": "title",
      "text": "Untitled presentation"
    },
    {
      "type": "text",
      "slot": "subtitle",
      "textRole": "subtitle",
      "text": "Add a concise executive subtitle."
    },
    {
      "type": "text",
      "slot": "meta",
      "textRole": "caption",
      "text": "Prepared with qraftPptx"
    },
    {
      "type": "shape",
      "slot": "visual",
      "shape": "rect",
      "style": {
        "opacity": 0.08
      }
    }
  ],
  "themeTokens": [
    "colors.bg",
    "colors.primary",
    "colors.text",
    "typography.display",
    "typography.body"
  ],
  "exportCompatibility": {
    "html": "native",
    "pdf": "native",
    "pptx": "native"
  }
}
